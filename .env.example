# OpenClaw Environment Variables
# DO NOT COMMIT ACTUAL VALUES — use this as a template for setup

# Timezone
TZ=America/New_York

# Maton API Gateway (for OAuth-managed third-party service connections)
MATON_API_KEY=<your-maton-api-key>

# GOG Account (for game library)
GOG_ACCOUNT=<your-gog-email>
GOG_KEYRING_PASSWORD=<your-gog-keyring-password>

# Hostinger API (VPS management)
HOSTINGER_API_TOKEN=<your-hostinger-api-token>

# OpenAI (embeddings, image generation, video)
OPENAI_API_KEY=<your-openai-api-key>

# Gemini (image/video generation, web search grounding)
GEMINI_API_KEY=<your-gemini-api-key>

# GitHub (repository access, issue automation)
GITHUB_TOKEN=<your-github-personal-access-token>

# Telegram (messaging, notifications)
TELEGRAM_BOT_TOKEN=<your-telegram-bot-token>
TELEGRAM_CHAT_ID=<your-chat-id>

# Optional: Model overrides
# OLLAMA_MODEL=dolphin3:8b
# GEMINI_MODEL=gemini-3-flash
