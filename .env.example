# Docker Compose Environment - REDACTED (no secrets)
# For credentials, see .env.secret (git-ignored)

# Node/Runtime
NODE_ENV=production

# OpenClaw
OPENCLAW_LOG_LEVEL=info

# API Keys (redacted — use .env.secret)
OPENAI_API_KEY=<your-key>
ANTHROPIC_API_KEY=<your-key>
GEMINI_API_KEY=<your-key>
HOSTINGER_API_TOKEN=<your-token>
MATON_API_KEY=<your-key>

# Database
QDRANT_HOST=memory-qdrant
QDRANT_PORT=6333
FALKORDB_HOST=memory-falkordb
FALKORDB_PORT=6379

# Ports
QDRANT_WEB_PORT=6334
FALKORDB_WEB_PORT=8001

# SSH Config
SSH_CONFIG_PATH=/data/.openclaw/.ssh/config
GIT_SSH_COMMAND=ssh -F /data/.openclaw/.ssh/config
