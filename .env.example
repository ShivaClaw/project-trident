# Environment Variables Template
# Copy this to .env.secret and fill in actual values from TOKENS&KEYS
# DO NOT commit .env.secret to version control

# OpenClaw Gateway
OPENCLAW_API_KEY=your_api_key_here
OPENCLAW_PORT=8080

# Database Connections
QDRANT_URL=http://memory-qdrant:6333
FALKORDB_URL=redis://memory-falkordb:6379

# Traefik / Let's Encrypt
TRAEFIK_ACME_EMAIL=brandongkirksey@gmail.com
LETSENCRYPT_EMAIL=brandongkirksey@gmail.com

# Third-party APIs
MATON_API_KEY=redacted
OPENAI_API_KEY=redacted
GEMINI_API_KEY=redacted
GROQ_API_KEY=redacted

# Hostinger API (if needed)
HOSTINGER_API_TOKEN=redacted

# GitHub API
GITHUB_TOKEN=redacted
GITHUB_USER=ShivaClaw

# Domain Configuration
PRIMARY_DOMAIN=trident-memory.com
OPENCLAW_DOMAIN=openclaw.trident-memory.com
QDRANT_DOMAIN=qdrant.trident-memory.com
FALKORDB_DOMAIN=falkordb.trident-memory.com

# Logging & Monitoring
LOG_LEVEL=info
DEBUG=false
